{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "node/no-unsupported-features/es-syntax": "off",
    "node/no-process-exit": "off"
  },
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "rules": {
        "node/no-unpublished-require": "off"
      }
    }
  ]
}